		"astro": "^7.0.6",
		"motion": "^12.42.2"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@biomejs/biome": "2.5.2",
		"@playwright/test": "^1.61.1",
		"@types/bun": "1.3.14",
		"@types/node": "^26.1.0",
		"typescript": "6.0.3",
		"vitest": "^4.1.9",
		"wrangler": "^4.107.0"
	}
}
